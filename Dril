<script>
    // 데이터
    const verbs = [
        {base: "become", past: "became", pp: "become"},
        {base: "begin", past: "began", pp: "begun"},
        {base: "break", past: "broke", pp: "broken"},
        {base: "bring", past: "brought", pp: "brought"},
        {base: "build", past: "built", pp: "built"},
        {base: "buy", past: "bought", pp: "bought"},
        {base: "catch", past: "caught", pp: "caught"},
        {base: "choose", past: "chose", pp: "chosen"},
        {base: "come", past: "came", pp: "come"},
        {base: "do", past: "did", pp: "done"},
        {base: "drink", past: "drank", pp: "drunk"},
        {base: "drive", past: "drove", pp: "driven"},
        {base: "eat", past: "ate", pp: "eaten"},
        {base: "fall", past: "fell", pp: "fallen"},
        {base: "feel", past: "felt", pp: "felt"},
        {base: "find", past: "found", pp: "found"},
        {base: "fly", past: "flew", pp: "flown"},
        {base: "forget", past: "forgot", pp: "forgotten"},
        {base: "freeze", past: "froze", pp: "frozen"},
        {base: "get", past: "got", pp: "gotten"},
        {base: "give", past: "gave", pp: "given"},
        {base: "go", past: "went", pp: "gone"},
        {base: "grow", past: "grew", pp: "grown"},
        {base: "have", past: "had", pp: "had"},
        {base: "hear", past: "heard", pp: "heard"},
        {base: "keep", past: "kept", pp: "kept"},
        {base: "know", past: "knew", pp: "known"},
        {base: "leave", past: "left", pp: "left"},
        {base: "lose", past: "lost", pp: "lost"},
        {base: "make", past: "made", pp: "made"},
        {base: "meet", past: "met", pp: "met"},
        {base: "run", past: "ran", pp: "run"},
        {base: "say", past: "said", pp: "said"},
        {base: "see", past: "saw", pp: "seen"},
        {base: "send", past: "sent", pp: "sent"},
        {base: "shake", past: "shook", pp: "shaken"},
        {base: "sing", past: "sang", pp: "sung"},
        {base: "sit", past: "sat", pp: "sat"},
        {base: "sleep", past: "slept", pp: "slept"},
        {base: "speak", past: "spoke", pp: "spoken"},
        {base: "spend", past: "spent", pp: "spent"},
        {base: "stand", past: "stood", pp: "stood"},
        {base: "swim", past: "swam", pp: "swum"},
        {base: "take", past: "took", pp: "taken"},
        {base: "teach", past: "taught", pp: "taught"},
        {base: "tell", past: "told", pp: "told"},
        {base: "think", past: "thought", pp: "thought"},
        {base: "throw", past: "threw", pp: "thrown"},
        {base: "understand", past: "understood", pp: "understood"},
        {base: "wake", past: "woke", pp: "woken"},
        {base: "wear", past: "wore", pp: "worn"},
        {base: "win", past: "won", pp: "won"},
        {base: "write", past: "wrote", pp: "written"},
        {base: "live", past: "lived", pp: "lived"},
        {base: "open", past: "opened", pp: "opened"},
        {base: "hold", past: "held", pp: "held"},
        {base: "ride", past: "rode", pp: "ridden"},
        {base: "sell", past: "sold", pp: "sold"},
        {base: "oversleep", past: "overslept", pp: "overslept"}
    ];

    const sentences = [
        {q: "Tell me about the house you lived in when you were a child.", qk: "어릴 적 살았던 집에 대해 이야기해 주세요.", template: "I ___ in a small apartment in Seoul.", verb: "live", answer: "lived"},
        {q: "Tell me about a time when you experienced a problem at home.", qk: "집에서 겪었던 문제에 대해 이야기해 주세요.", template: "The water pipe ___ in the middle of winter.", verb: "break", answer: "broke"},
        {q: "Tell me about your first overseas trip.", qk: "처음으로 갔던 해외 여행에 대해 자세히 이야기해 주세요.", template: "I ___ to Japan for the first time in 2015.", verb: "go", answer: "went"},
        {q: "Tell me about a memorable incident during a trip.", qk: "여행 중 겪었던 잊지 못할 에피소드를 말해 주세요.", template: "I ___ my passport at the airport.", verb: "lose", answer: "lost"},
        {q: "Tell me about opening your first bank account.", qk: "처음으로 은행 계좌를 개설했던 때를 기억하나요?", template: "I ___ an adult and needed my own account.", verb: "become", answer: "became"},
        {q: "Tell me about a memorable movie you saw.", qk: "최근에 본 영화 중에서 가장 기억에 남는 영화는?", template: "I ___ a fantastic thriller last month.", verb: "see", answer: "saw"},
        {q: "How did you first get interested in music?", qk: "처음 음악에 관심을 갖게 된 계기가 무엇인가요?", template: "My mom ___ me piano when I was seven.", verb: "teach", answer: "taught"},
        {q: "Tell me about a special experience at a park.", qk: "공원에서 겪었던 특별한 경험을 말해 주세요.", template: "I ___ my best friend at the park.", verb: "meet", answer: "met"},
        {q: "Tell me about going to the beach as a child.", qk: "어릴 적 해변에 갔던 기억에 대해 이야기해 주세요.", template: "My family ___ to the coast every summer.", verb: "drive", answer: "drove"},
        {q: "Any interesting experiences on public transportation?", qk: "대중교통을 이용하면서 겪었던 흥미로운 일은?", template: "I ___ asleep on the subway once.", verb: "fall", answer: "fell"},
        {q: "How did you start your current hobby?", qk: "현재의 취미를 처음 시작하게 된 계기는?", template: "A friend ___ me a guitar as a gift.", verb: "give", answer: "gave"},
        {q: "Tell me about the first time you used the internet.", qk: "처음으로 인터넷을 사용했던 때를 이야기해 주세요.", template: "I ___ my first computer in elementary school.", verb: "get", answer: "got"},
        {q: "When did a gadget or computer break down?", qk: "전자기기나 컴퓨터가 고장 났던 경험은?", template: "My laptop screen ___ completely black.", verb: "go", answer: "went"},
        {q: "When did you first meet your best friend?", qk: "가장 친한 친구를 처음 만났을 때의 상황은?", template: "We ___ next to each other in class.", verb: "stand", answer: "stood"},
        {q: "Tell me about a problem at a restaurant.", qk: "식당에서 문제가 있었던 경험을 말해 주세요.", template: "The waiter ___ the wrong dish.", verb: "bring", answer: "brought"},
        {q: "Any memorable incident at a cafe?", qk: "카페에서 있었던 잊지 못할 에피소드는?", template: "I ___ my coffee too fast.", verb: "drink", answer: "drank"},
        {q: "An unexpected situation while shopping?", qk: "쇼핑을 하다가 겪었던 예상치 못한 상황은?", template: "I ___ a shirt but it was the wrong size.", verb: "choose", answer: "chose"},
        {q: "When were you late for an appointment?", qk: "약속 시간에 늦었던 경험에 대해 이야기해 주세요.", template: "I ___ and woke up 30 minutes late.", verb: "oversleep", answer: "overslept"},
        {q: "Your most memorable childhood holiday?", qk: "어릴 적 가장 기억에 남는 명절이나 휴일은?", template: "My family ___ a big reunion during Chuseok.", verb: "hold", answer: "held"},
        {q: "Something surprising, sad, or happy recently?", qk: "최근에 겪은 가장 놀라운 일은?", template: "I ___ a small lottery prize last week.", verb: "win", answer: "won"}
    ];

    // 상태
    let currentIndex = 0;
    let completedCount = 0;
    let learnedVerbs = new Set();
    let timeLeft = 3;
    let interval;

    // DOM
    const questionNum = document.getElementById('questionNum');
    const question = document.getElementById('question');
    const questionKr = document.getElementById('questionKr');
    const sentence = document.getElementById('sentence');
    const timer = document.getElementById('timer');
    const timerNum = document.getElementById('timerNum');
    const answerBox = document.getElementById('answerBox');
    const answerText = document.getElementById('answerText');
    const verbForms = document.getElementById('verbForms');
    const completedEl = document.getElementById('completed');
    const verbCountEl = document.getElementById('verbCount');
    const gameCard = document.getElementById('gameCard');

    // 문제 로드
    function loadQuestion() {
        if (currentIndex >= sentences.length) {
            showComplete();
            return;
        }

        const s = sentences[currentIndex];
        
        questionNum.textContent = `Question ${currentIndex + 1} / ${sentences.length}`;
        question.textContent = s.q;
        questionKr.textContent = s.qk;
        
        const highlighted = s.template.replace(
            `___`,
            `<span class="blank">___</span>`
        );
        sentence.innerHTML = highlighted;

        timer.classList.remove('hidden');
        answerBox.classList.add('hidden');
        
        timeLeft = 3;
        timerNum.textContent = timeLeft;
        
        startTimer();
    }

    // 타이머
    function startTimer() {
        clearInterval(interval);
        interval = setInterval(() => {
            timeLeft--;
            timerNum.textContent = timeLeft;
            
            if (timeLeft <= 0) {
                clearInterval(interval);
                showAnswer();
            }
        }, 1000);
    }

    // 정답 공개
    function showAnswer() {
        const s = sentences[currentIndex];
        const v = verbs.find(verb => verb.base === s.verb);
        
        timer.classList.add('hidden');
        answerBox.classList.remove('hidden');
        
        answerText.textContent = s.answer;
        verbForms.textContent = `${v.base} - ${v.past} - ${v.pp}`;
        
        learnedVerbs.add(s.verb);
        completedCount++;
        
        completedEl.textContent = completedCount;
        verbCountEl.textContent = `${learnedVerbs.size}/100`;
    }

    // 다음 문제
    function nextQuestion() {
        if (!answerBox.classList.contains('hidden')) {
            currentIndex++;
            loadQuestion();
        }
    }

    // 완료
    function showComplete() {
        gameCard.innerHTML = `
            <div class="complete">
                <h2>🎉 완료!</h2>
                <p>총 ${sentences.length}개 문장 완료!</p>
                <p>학습한 동사: ${learnedVerbs.size}개</p>
                <p style="margin-top: 20px; color: #00ff88;">OPIc AL 목표를 향해<br>한 걸음 더 가까워졌습니다!</p>
            </div>
        `;
    }

    // 터치/클릭으로 다음 문제
    document.addEventListener('click', (e) => {
        if (!answerBox.classList.contains('hidden')) {
            nextQuestion();
        }
    });
    
    // 스페이스바 (PC용)
    document.addEventListener('keydown', (e) => {
        if (e.code === 'Space') {
            e.preventDefault();
            nextQuestion();
        }
    });

    // 시작
    loadQuestion();
</script>
